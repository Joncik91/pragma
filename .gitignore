# Machine-local Claude Code settings
.claude/settings.local.json

# Internal brainstorming trail — dated process notes from design sessions.
# These are working scaffolding; the curated public docs live in docs/
# (design.md, roadmap.md) and are committed.
docs/superpowers/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
build/
dist/
*.egg

# Virtual environments
.venv/
venv/
env/

# OS and editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Gate state is machine-local. The audit log (.pragma/audit.jsonl)
# is evidence and stays committed; state.json drifts per session.
.pragma/state.json
.pragma/state.json.lock

# Per-run test artifacts (v0.4: span dumps + JUnit XML). Generated by
# pragma_sdk's pytest plugin and pytest --junit-xml. Pragma itself
# dogfoods v0.4 so these show up in our own repo on every test run.
.pragma/spans/
.pragma/pytest-junit.xml
packages/*/.pragma/spans/
packages/*/.pragma/pytest-junit.xml
